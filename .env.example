# Required Environment Variables
DATABASE_URL=postgresql://user:password@localhost:5432/accessibooks
SESSION_SECRET=gYp3NE9r8I50XubixAfnGBjz2wvOcU7D
PORT=5000
# After pulling schema changes (e.g. user_preferences), run: npm run db:push

# Optional: S3/GCS for uploaded audiobooks (admin)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# GCS_BUCKET=
# GCS_KEY_FILE=
# ADMIN_EMAILS=admin@example.com

# Optional: Google Play / Google Books (catalog + read links)
# Get key: https://console.cloud.google.com/apis/credentials
# GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Optional: Amazon / Audible (Product Advertising API 5.0; requires Associates/affiliate account)
# PA-API is deprecated April 2026; migrate to Creators API when available.
# AMAZON_ACCESS_KEY=your-access-key
# AMAZON_SECRET_KEY=your-secret-key
# AMAZON_PARTNER_TAG=your-partner-tag
# AMAZON_HOST=webservices.amazon.com
# AMAZON_REGION=us-east-1

# Optional: Uncomment to enable OAuth providers
# FACEBOOK_APP_ID=
# MICROSOFT_CLIENT_ID=
# AUTH0_DOMAIN=
